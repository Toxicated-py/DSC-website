{
  "name": "dsc-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "api:install": "python -m pip install -r backend/requirements.txt",
    "api:dev": "python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8001",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:link": "npx supabase link --project-ref tpfyvmezktigmtyzixez",
    "supabase:pull": "npx supabase db pull",
    "supabase:push": "npx supabase db push",
    "sync:status": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode status",
    "sync:local-reset": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode local-reset",
    "sync:pull-schema": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode pull-schema",
    "sync:push-schema": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode push-schema",
    "sync:dump-public-data": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode dump-public-data",
    "sync:restore-public-data": "powershell -ExecutionPolicy Bypass -File scripts/supabase-sync.ps1 -Mode restore-public-data"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@zxing/browser": "^0.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "0.487.0",
    "qrcode.react": "^4.2.0",
    "react-router-dom": "^7.17.0",
    "sonner": "2.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
