{
  "name": "dsc-website",
  "private": true,
  "version": "0.0.1",
  "description": "Official Data Sarathi website for the Data Science Club, School of Mathematical Sciences, Tribhuvan University.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Toxicated-py/DSC-website.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "api:install": "python -m pip install -r backend/requirements.txt",
    "api:dev": "python -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8001",
    "supabase:link": "npx supabase link --project-ref $SUPABASE_PROJECT_REF",
    "supabase:pull": "npx supabase db pull",
    "supabase:push": "npx supabase db push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@zxing/browser": "^0.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "0.487.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0",
    "sonner": "2.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "4.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.1.12",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
